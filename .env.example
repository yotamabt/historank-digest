# ---------------------------------------------------------------------------
# Agent rotation
# ---------------------------------------------------------------------------
# Which AI agent writes the digest.
# Values: gemini | claude | codex | deepseek | auto (default)
# "auto" picks one of the four agents at random each run
# DIGEST_AGENT=auto

# Agent loop settings (apply to all non-Gemini agents)
# AGENT_TIMEOUT=1200       # seconds per attempt (default 20 min)
# AGENT_RETRIES=2          # total attempts before aborting
# AGENT_RETRY_DELAY=30     # seconds between retries

# ---------------------------------------------------------------------------
# Gemini CLI
# ---------------------------------------------------------------------------
# Option A: API key from https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key
#
# Option B: Google account OAuth (free tier — 60 req/day on Gemini 2.5 Pro)
#   Run `gemini` once interactively on the VPS to authenticate.
#   Credentials are cached at ~/.gemini/ and picked up automatically.
#   Leave GEMINI_API_KEY unset when using this option.
#
# Model (default: auto — lets Gemini CLI choose the best available model)
# GEMINI_MODEL=auto

# ---------------------------------------------------------------------------
# Claude Code CLI — https://console.anthropic.com/settings/keys
# ---------------------------------------------------------------------------
# Option A: API key
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option B: OAuth — run `claude` once interactively on the host to log in.
#   Credentials are cached at ~/.claude/ and mounted into the container.
#   Leave ANTHROPIC_API_KEY unset when using this option.
#
# Non-root user for --dangerously-skip-permissions (required when container runs as root).
# The Dockerfile creates an 'agent' user (uid 1001) for this purpose.
# CLAUDE_USER=agent

# ---------------------------------------------------------------------------
# OpenAI Codex CLI — https://platform.openai.com/api-keys
# ---------------------------------------------------------------------------
# Option A: API key
# OPENAI_API_KEY=sk-...
#
# Option B: OAuth — run `codex` once interactively on the host to log in.
#   Credentials are cached at ~/.codex/ and mounted into the container.
#   Leave OPENAI_API_KEY unset when using this option.
#
# Model used in codex-config-template.yaml (default: o4-mini)
# CODEX_MODEL=gpt-5.4-mini

# ---------------------------------------------------------------------------
# DeepSeek — https://platform.deepseek.com/api_keys
# (API only — no CLI; web search requires SERPER_API_KEY below)
# ---------------------------------------------------------------------------
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat   # must support tool calling; deepseek-reasoner does NOT

# ---------------------------------------------------------------------------
# Web search (Serper.dev) — used by the DeepSeek agent for google_web_search
# Get a free key at https://serper.dev
# ---------------------------------------------------------------------------
# SERPER_API_KEY=...

# ---------------------------------------------------------------------------
# Image storage (Pronto.io — https://www.getpronto.io)
# ---------------------------------------------------------------------------
PRONTO_API_KEY=your-pronto-api-key

# ---------------------------------------------------------------------------
# Image generation (Wavespeed)
# ---------------------------------------------------------------------------
WAVESPEED_API_KEY=your-wavespeed-api-key
WAVESPEED_MODEL=wavespeed-ai/flux-dev

# ---------------------------------------------------------------------------
# HistoRank MCP server HTTP URL
# ---------------------------------------------------------------------------
HISTORANK_MCP_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# Paths (override for production deployments)
# ---------------------------------------------------------------------------
OUTPUT_DIR=/var/www/historank/digests
DIGEST_DIR=/opt/historank-digest
LOG_DIR=/opt/historank-digest/logs
